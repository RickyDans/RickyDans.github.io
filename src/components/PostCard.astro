---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../lib/content';

type Props = {
  post: CollectionEntry<'blog'>;
  compact?: boolean;
};

const { post, compact = false } = Astro.props;
---

<article class:list={['post-card', { compact }]}>
  <div class="post-card-meta">
    <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
    <a href={`/blog/category/${post.data.categorySlug}/`}>{post.data.category}</a>
  </div>
  <h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
  <p>{post.data.description}</p>
  {
    !compact && (
      <div class="tag-row">
        {post.data.tags.slice(0, 4).map((tag) => <span>{tag}</span>)}
      </div>
    )
  }
</article>
